# .env.example - Copy to .env and customize

# Database Configuration
DB_NAME=royal_clinic
DB_USER=royal_user
DB_PASSWORD=change_me_in_production
MYSQL_ROOT_PASSWORD=root_change_me

# Django Settings
DEBUG=True
SECRET_KEY=django-insecure-generate-a-secure-key-here
ALLOWED_HOSTS=localhost,127.0.0.1,web

# Static Files (set to true for production)
COLLECT_STATIC=false

# Superuser (development only)
CREATE_SUPERUSER=false
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@royalclinic.com
DJANGO_SUPERUSER_PASSWORD=admin123